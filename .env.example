# Copy to .env and adjust. All values have sane defaults baked into compose.

# Host port the registry listens on.
REGISTRY_PORT=5000

# Retention: tags kept per repository (newest by push time). Older tags pruned.
KEEP_LAST_N=10

# How often the janitor sweeps + garbage-collects (seconds). 3600 = hourly.
JANITOR_INTERVAL_SECS=3600

# Pass --delete-untagged to garbage-collect so orphaned manifest revisions and
# their blobs are reclaimed. Set to false only on very old registry versions
# with broken manifest-list handling.
GC_DELETE_UNTAGGED=true
